{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Europe/Helsinki",
  "schedule": ["* 21-22 * * 3"],
  "ignorePresets": [
    ":ignoreModulesAndTests"
  ],
  "rebaseWhen": "conflicted",
  "enabledManagers": [
    "tflint-plugin",
    "nuget",
    "dockerfile"
  ],
  "packageRules": [
    {
      "matchManagers": ["tflint-plugin"],
      "enabled": true
    },
    {
      "matchManagers": [
        "nuget",
        "dockerfile"
      ],
      "matchPackageNames": [
        "!mcr.microsoft.com/playwright/dotnet"
      ],
      "enabled": false
    },
    {
      "matchManagers": [
        "nuget",
        "dockerfile"
      ],
      "matchPackageNames": [
        "Microsoft.Playwright",
        "mcr.microsoft.com/playwright/dotnet"
      ],
      "rangeStrategy": "bump",
      "commitMessageAction": "Update",
      "commitMessageTopic": "playwright",
      "commitMessageExtra": "to {{{prettyNewVersion}}}",
      "groupName": "playwright",
      "enabled": true
    }
  ]
}
